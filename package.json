{
  "name": "unbroken",
  "version": "1.0.33",
  "description": "Detect broken links in markdown files",
  "type": "module",
  "main": "./lib/checker.js",
  "exports": {
    ".": {
      "import": "./lib/checker.js",
      "types": "./lib/checker.d.ts"
    }
  },
  "scripts": {
    "test": "yarn build && tsc -p test && node --test test/test.js test/test.mock-web.js",
    "test:local": "yarn build && tsc -p test && node --test test/test.js test/test.mock-web.js",
    "build": "tsc -p src",
    "lint": "eslint src/ test/",
    "format:check": "prettier --check src/ test/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/asklar/unbroken.git"
  },
  "bin": {
    "unbroken": "./bin/index.js"
  },
  "author": "Alexander Sklar",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "chalk": "^5.4.0",
    "command-line-args": "^6.0.0",
    "command-line-usage": "^7.0.0",
    "micromatch": "^4.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/command-line-args": "^5.2.3",
    "@types/command-line-usage": "^5.0.4",
    "@types/micromatch": "^4.0.9",
    "@types/node": "^22.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  },
  "files": [
    "lib/**",
    "bin/**"
  ]
}